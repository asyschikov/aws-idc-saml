    "Boolean": {
      "type": "boolean"
    },
    "StringList": {
      "type": "list",
      "member": {
        "shape": "String"
      }
    },
    "CreateApplicationInstanceRequest": {
      "type": "structure",
      "required": [
        "templateId",
        "name"
