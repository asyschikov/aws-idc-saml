{
  "version": "2.0",
  "metadata": {
    "apiVersion": "2020-07-20",
    "endpointPrefix": "sso",
    "jsonVersion": "1.1",
    "protocol": "json",
    "serviceFullName": "AWS IAM Identity Center SAML Management",
    "serviceAbbreviation": "IDC SAML",
    "serviceId": "IDC SAML",
    "signatureVersion": "v4",
    "signingName": "sso",
    "targetPrefix": "SWBService",
    "uid": "idc-saml-2020-07-20"
