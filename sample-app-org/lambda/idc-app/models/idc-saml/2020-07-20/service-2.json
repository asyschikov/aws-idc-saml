      "input": {
        "shape": "CreateApplicationInstanceRequest"
      },
      "output": {
        "shape": "CreateApplicationInstanceResponse"
      },
      "documentation": "<p>Creates a SAML application instance using the specified template.</p>"
    },
    "GetApplicationInstance": {
      "name": "GetApplicationInstance",
      "http": {
        "method": "POST",
        "requestUri": "/"
      },
