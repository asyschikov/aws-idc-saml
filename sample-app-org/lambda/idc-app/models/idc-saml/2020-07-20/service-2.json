        "method": "POST",
        "requestUri": "/"
      },
      "input": {
        "shape": "UpdateApplicationInstanceResponseSchemaConfigurationRequest"
      },
      "documentation": "<p>Configures SAML response attribute schema (format and inclusion settings).</p>"
    },
    "UpdateApplicationInstanceStatus": {
      "name": "UpdateApplicationInstanceStatus",
