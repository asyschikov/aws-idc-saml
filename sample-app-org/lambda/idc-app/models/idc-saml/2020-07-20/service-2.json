        "method": "POST",
        "requestUri": "/"
      },
      "input": {
        "shape": "UpdateApplicationInstanceServiceProviderConfigurationRequest"
      },
      "documentation": "<p>Configures SAML service provider settings (ACS URL, audience).</p>"
