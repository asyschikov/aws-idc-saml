        "method": "POST",
        "requestUri": "/"
      },
      "input": {
        "shape": "UpdateApplicationInstanceDisplayDataRequest"
      },
      "documentation": "<p>Sets the display name and description for an application instance.</p>"
    },
    "UpdateApplicationInstanceServiceProviderConfiguration": {
      "name": "UpdateApplicationInstanceServiceProviderConfiguration",
