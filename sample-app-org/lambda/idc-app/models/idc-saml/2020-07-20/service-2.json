        "method": "POST",
        "requestUri": "/"
      },
      "input": {
        "shape": "UpdateApplicationInstanceStatusRequest"
      },
      "documentation": "<p>Enables or disables an application instance.</p>"
    },
    "DeleteApplicationInstance": {
