      "members": {
        "templateId": {
          "shape": "TemplateId",
          "documentation": "<p>The template ID. Use tpl-50e590700beb5208 for Custom SAML 2.0 applications.</p>"
        },
        "name": {
          "shape": "String",
          "documentation": "<p>An internal name for the application (typically a UUID).</p>"
        }
      }
    },
    "CreateApplicationInstanceResponse": {
      "type": "structure",
