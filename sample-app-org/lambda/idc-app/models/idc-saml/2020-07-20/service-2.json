        "shape": "GetApplicationInstanceRequest"
      },
      "output": {
        "shape": "GetApplicationInstanceResponse"
      },
      "documentation": "<p>Retrieves full application instance details including SAML metadata URL.</p>"
    },
    "UpdateApplicationInstanceDisplayData": {
      "name": "UpdateApplicationInstanceDisplayData",
